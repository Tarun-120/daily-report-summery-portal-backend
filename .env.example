# =====================================================
# Daily Report Portal — Backend env template
# Copy this to `.env` and fill in real values.
# =====================================================

# ---- PostgreSQL ----
POSTGRES_DB=drp
POSTGRES_USER=drp_user
POSTGRES_PASSWORD=changeme_in_real_env
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# DATABASE_URL is computed from the above; both Django and FastAPI read this.
DATABASE_URL=postgresql://drp_user:changeme_in_real_env@postgres:5432/drp

# ---- Django ----
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@acme.com
DJANGO_SUPERUSER_PASSWORD=admin12345

# ---- FastAPI ----
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# CORS — comma-separated list of frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- pgAdmin ----
PGADMIN_DEFAULT_EMAIL=admin@acme.com
PGADMIN_DEFAULT_PASSWORD=admin12345
